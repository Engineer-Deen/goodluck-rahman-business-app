{
  "name": "goodluck-rahman-enterprise",
  "version": "4.6.7",
  "description": "Good Luck Rahman Enterprise desktop app",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build:web": "node scripts/write-firebase-config.js",
    "dist": "npm run package",
    "dist:exe": "npm run package",
    "dist:installer": "electron-builder --win nsis --x64 --config.directories.output=package-output/win",
    "dist:web-installer": "electron-builder --win nsis-web --x64 --config.directories.output=package-output/win",
    "dist:portable": "electron-builder --win portable --x64 --config.directories.output=package-output/win",
    "release:github": "electron-builder --win nsis --x64 --publish always --config.directories.output=package-output/win",
    "release:update": "node scripts/build-update-release.js",
    "release:update:win": "node scripts/build-update-release.js --platform=win",
    "package": "node scripts/package.js"
  },
  "author": "Good Luck Rahman",
  "license": "MIT",
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2"
  },
  "build": {
    "appId": "com.goodluck.rahman",
    "productName": "Good Luck Rahman Enterprise",
    "asar": false,
    "files": [
      "src/**/*",
      "package.json",
      "package-lock.json",
      ".env.local"
    ],
    "directories": {
      "buildResources": "src/assets",
      "output": "package-output"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Engineer-Deen",
        "repo": "goodluck-rahman-business-app"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.business",
      "icon": "src/assets/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
